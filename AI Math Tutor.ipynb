import sympy as sp
import re

print("AI Math Tutor")

problem = input("Enter your math problem: ")

try:

    # Convert formats like 2x → 2*x
    problem = re.sub(r'(\d)([a-zA-Z])', r'\1*\2', problem)

    # Algebra equation
    if "=" in problem:
        left, right = problem.split("=")

        left_expr = sp.sympify(left)
        right_expr = sp.sympify(right)

        equation = sp.Eq(left_expr, right_expr)

        variables = list(equation.free_symbols)

        if variables:
            solution = sp.solve(equation, variables)
            print("Solution:", solution)
        else:
            print("No variable found in the equation.")

    # Simplify
    elif problem.lower().startswith("simplify"):
        expr = problem.replace("simplify", "")
        expr = sp.sympify(expr)
        print("Simplified:", sp.simplify(expr))

    # Expand
    elif problem.lower().startswith("expand"):
        expr = problem.replace("expand", "")
        expr = sp.sympify(expr)
        print("Expanded:", sp.expand(expr))

    # Factor
    elif problem.lower().startswith("factor"):
        expr = problem.replace("factor", "")
        expr = sp.sympify(expr)
        print("Factored:", sp.factor(expr))

    # Derivative
    elif problem.lower().startswith("diff"):
        expr = problem.replace("diff", "")
        expr = sp.sympify(expr)

        variables = list(expr.free_symbols)

        if variables:
            print("Derivative:", sp.diff(expr, variables[0]))
        else:
            print("No variable found for differentiation.")

    # Integral
    elif problem.lower().startswith("integrate"):
        expr = problem.replace("integrate", "")
        expr = sp.sympify(expr)

        variables = list(expr.free_symbols)

        if variables:
            print("Integral:", sp.integrate(expr, variables[0]))
        else:
            print("No variable found for integration.")

    # Arithmetic calculation
    else:
        expr = sp.sympify(problem)
        print("Answer:", expr.evalf())

except:
    print("Invalid math problem. Please enter a valid expression.")
